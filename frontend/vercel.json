{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://nexusops-api.lucasughelli.workers.dev/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}
